<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Email Me</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .gradient-bg {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/dashboard" class="text-xl font-bold gradient-bg bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-blue-600">
            Email Me
          </a>
        </div>
        <div class="flex space-x-4">
          <a href="/alias" class="text-gray-700 hover:text-gray-900">Aliases</a>
          <a href="/pricing" class="text-gray-700 hover:text-gray-900">Pricing</a>
          <a href="/logout" class="px-4 py-2 rounded-lg border border-red-600 text-red-600 hover:bg-red-50 transition">
            Logout
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Dashboard Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Welcome Section -->
    <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 mb-2">Welcome back, <%= username %>!</h1>
          <p class="text-gray-600">Manage your email forwarding settings below.</p>
        </div>
        <div class="text-right">
          <div class="text-sm text-gray-500">Account Email</div>
          <div class="font-medium text-gray-900"><%= email %></div>
        </div>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="text-sm text-gray-500 mb-1">Current Plan</div>
        <div class="text-2xl font-bold text-gray-900 mb-2"><%= plan %></div>
        <% if plan == "Free" %>
          <a href="/pricing" class="text-sm text-purple-600 hover:text-purple-700">Upgrade Plan →</a>
        <% else %>
          <span class="text-sm text-green-600">Active Subscription</span>
        <% end %>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="text-sm text-gray-500 mb-1">Total Aliases</div>
        <div class="text-2xl font-bold text-gray-900 mb-2"><%= alias_count %></div>
        <a href="/alias" class="text-sm text-purple-600 hover:text-purple-700">Manage Aliases →</a>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="text-sm text-gray-500 mb-1">Forwarding Address</div>
        <div class="text-md font-medium text-gray-900 truncate"><%= forward_to %></div>
        <a href="/settings" class="text-sm text-purple-600 hover:text-purple-700">Change →</a>
      </div>
    </div>

    <!-- Recent Aliases -->
    <div class="bg-white rounded-lg shadow-sm">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex justify-between items-center">
          <h2 class="text-lg font-semibold text-gray-900">Your Aliases</h2>
          <a href="/alias" class="px-4 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white text-sm hover:opacity-90 transition">
            + Create New Alias
          </a>
        </div>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email Address</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Forwards To</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% if recent_aliases.empty? %>
              <tr>
                <td colspan="4" class="px-6 py-8 text-center text-gray-500">
                  No aliases yet. Click "Create New Alias" to get started.
                </td>
              </tr>
            <% else %>
              <% recent_aliases.each do |alias_item| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900"><%= alias_item[:full_email] %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-600"><%= alias_item[:forward_to] %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                      Active
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                    <a href="/alias/delete?id=<%= alias_item[:id] %>" class="text-red-600 hover:text-red-800" onclick="return confirm('Delete this alias?')">Delete</a>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <% if recent_aliases.size >= 5 %>
        <div class="px-6 py-4 border-t border-gray-200 text-right">
          <a href="/alias" class="text-sm text-purple-600 hover:text-purple-700">View All Aliases →</a>
        </div>
      <% end %>
    </div>

    <!-- Upgrade Prompt for Free Users -->
    <% if plan == "Free" && alias_count >= 1 %>
      <div class="mt-8 gradient-bg rounded-lg p-6">
        <div class="flex justify-between items-center">
          <div>
            <h3 class="text-white font-semibold text-lg mb-1">Go Beyond One Alias</h3>
            <p class="text-purple-100 text-sm">Upgrade to Pro for custom domains and unlimited aliases.</p>
          </div>
          <a href="/pricing" class="px-6 py-2 rounded-lg bg-white text-purple-600 font-semibold hover:bg-gray-100 transition">
            View Plans
          </a>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-8 mt-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm">&copy; 2026 Email Me. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
