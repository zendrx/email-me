<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing - Email Me</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .gradient-bg {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/" class="text-xl font-bold gradient-bg bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-blue-600">
            Email Me
          </a>
        </div>
        <div class="flex space-x-4">
          <a href="/" class="text-gray-700 hover:text-gray-900">Home</a>
          <a href="/pricing" class="text-gray-700 hover:text-gray-900">Pricing</a>
          <a href="/signup" class="px-4 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white hover:opacity-90 transition">
            Sign Up
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Pricing Section -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Simple, Transparent Pricing</h1>
      <p class="text-xl text-gray-600">Choose the plan that works for you</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Free Plan -->
      <div class="border rounded-lg p-8 text-center bg-white">
        <h3 class="text-2xl font-bold mb-2">Free</h3>
        <p class="text-4xl font-bold text-gray-900 mb-4">$0</p>
        <p class="text-gray-600 mb-6">Forever free</p>
        <ul class="text-left space-y-3 mb-8">
          <li class="flex items-center">✓ One @<?= domain ?> address</li>
          <li class="flex items-center">✓ Forward to Gmail or iCloud</li>
          <li class="flex items-center">✓ Basic support</li>
        </ul>
        <a href="/signup" class="block text-center px-6 py-3 rounded-lg border border-purple-600 text-purple-600 font-semibold hover:bg-purple-50 transition">
          Get Started
        </a>
      </div>

      <!-- Pro Plan -->
      <div class="border-2 border-purple-600 rounded-lg p-8 text-center bg-white relative">
        <div class="absolute top-0 right-0 bg-purple-600 text-white px-3 py-1 rounded-bl-lg rounded-tr-lg text-sm">
          Popular
        </div>
        <h3 class="text-2xl font-bold mb-2">Pro</h3>
        <p class="text-4xl font-bold text-gray-900 mb-4">$2.99<span class="text-lg text-gray-600">/mo</span></p>
        <p class="text-gray-600 mb-6">Billed monthly</p>
        <ul class="text-left space-y-3 mb-8">
          <li class="flex items-center">✓ Custom domains (up to 3)</li>
          <li class="flex items-center">✓ Unlimited aliases</li>
          <li class="flex items-center">✓ Priority support</li>
          <li class="flex items-center">✓ Team members (up to 5)</li>
        </ul>
        <a href="/pro" class="block text-center px-6 py-3 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold hover:opacity-90 transition">
          Choose Pro
        </a>
      </div>

      <!-- Unlimited Plan -->
      <div class="border rounded-lg p-8 text-center bg-white">
        <h3 class="text-2xl font-bold mb-2">Unlimited</h3>
        <p class="text-4xl font-bold text-gray-900 mb-4">$6.99<span class="text-lg text-gray-600">/mo</span></p>
        <p class="text-gray-600 mb-6">Billed monthly</p>
        <ul class="text-left space-y-3 mb-8">
          <li class="flex items-center">✓ Unlimited custom domains</li>
          <li class="flex items-center">✓ Unlimited aliases</li>
          <li class="flex items-center">✓ Telegram bot integration</li>
          <li class="flex items-center">✓ View emails in Telegram</li>
          <li class="flex items-center">✓ Reply from Telegram</li>
          <li class="flex items-center">✓ Priority support</li>
          <li class="flex items-center">✓ Unlimited team members</li>
          <li class="flex items-center">✓ API access</li>
        </ul>
        <a href="/unlimited" class="block text-center px-6 py-3 rounded-lg border border-purple-600 text-purple-600 font-semibold hover:bg-purple-50 transition">
          Choose Unlimited
        </a>
      </div>
    </div>
  </div>

  <!-- FAQ Section -->
  <div class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Frequently Asked Questions</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Can I upgrade or downgrade anytime?</h3>
          <p class="text-gray-600">Yes, you can change your plan at any time. Changes take effect immediately.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">How does the Telegram bot work?</h3>
          <p class="text-gray-600">Unlimited plan users get access to our Telegram bot. Connect your account and receive email notifications, read emails, and reply directly from Telegram.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">What email providers can I forward to?</h3>
          <p class="text-gray-600">Any email provider that accepts incoming mail - Gmail, Outlook, Yahoo, iCloud, ProtonMail, custom domains, and more.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Do you store my emails?</h3>
          <p class="text-gray-600">No. We only forward emails. We never store your messages on our servers.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p>&copy; 2026 Email Me. All rights reserved.</p>
      <div class="flex justify-center space-x-6 mt-4">
        <a href="/terms" class="text-gray-400 hover:text-white">Terms</a>
        <a href="/privacy" class="text-gray-400 hover:text-white">Privacy</a>
        <a href="/contact" class="text-gray-400 hover:text-white">Contact</a>
      </div>
    </div>
  </footer>
</body>
</html>
