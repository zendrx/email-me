<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Email Me - Professional Email Addresses Made Simple</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .gradient-bg {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <span class="text-xl font-bold gradient-bg bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-blue-600">
            Email Me
          </span>
        </div>
        <div class="flex space-x-4">
          <a href="#features" class="text-gray-700 hover:text-gray-900">Features</a>
          <a href="/pricing" class="text-gray-700 hover:text-gray-900">Pricing</a>
          <a href="/signup" class="px-4 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white hover:opacity-90 transition">
            Sign Up
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <main>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center">
        <h1 class="text-5xl font-bold text-gray-900 mb-6">
          Professional Email Address
          <span class="gradient-bg bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-blue-600">
            Without the Price Tag
          </span>
        </h1>
        <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
          Get yourname@<?= domain ?> email address. Forward to your existing Gmail or iCloud inbox. No software needed.
        </p>
        <div class="flex justify-center space-x-4">
          <a href="/signup" class="px-6 py-3 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold hover:opacity-90 transition">
            Get Started Free
          </a>
          <a href="#how-it-works" class="px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 transition">
            How It Works
          </a>
        </div>
      </div>
    </div>

    <!-- How It Works -->
    <div id="how-it-works" class="bg-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 gradient-bg rounded-full flex items-center justify-center text-white text-xl font-bold mx-auto mb-4">1</div>
            <h3 class="text-xl font-semibold mb-2">Sign Up</h3>
            <p class="text-gray-600">Create your free account in seconds</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 gradient-bg rounded-full flex items-center justify-center text-white text-xl font-bold mx-auto mb-4">2</div>
            <h3 class="text-xl font-semibold mb-2">Choose Username</h3>
            <p class="text-gray-600">Pick yourname@<?= domain ?> - check availability instantly</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 gradient-bg rounded-full flex items-center justify-center text-white text-xl font-bold mx-auto mb-4">3</div>
            <h3 class="text-xl font-semibold mb-2">Start Receiving</h3>
            <p class="text-gray-600">Emails forwarded to your real inbox. Reply normally.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Features -->
    <div id="features" class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Features</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex items-start space-x-3">
            <div class="text-green-500 text-xl">✓</div>
            <div>
              <h3 class="font-semibold">Free @<?= domain ?> Address</h3>
              <p class="text-gray-600">Get a professional email address at zero cost</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <div class="text-green-500 text-xl">✓</div>
            <div>
              <h3 class="font-semibold">Custom Domains</h3>
              <p class="text-gray-600">Use your own domain with paid plans</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <div class="text-green-500 text-xl">✓</div>
            <div>
              <h3 class="font-semibold">Multiple Aliases</h3>
              <p class="text-gray-600">Create different addresses for different purposes</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <div class="text-green-500 text-xl">✓</div>
            <div>
              <h3 class="font-semibold">Team Management</h3>
              <p class="text-gray-600">Share domains and aliases with your team</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Unlimited Plan Highlight -->
    <div class="gradient-bg py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Unlimited Plan Exclusive</h2>
        <p class="text-xl text-purple-100 mb-8 max-w-2xl mx-auto">
          Manage your entire email forwarding setup from Telegram. View emails, reply, and manage aliases without leaving your chat.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-3xl mx-auto">
          <div class="bg-white bg-opacity-10 rounded-lg p-6">
            <div class="text-white text-3xl mb-3">📨</div>
            <h3 class="text-white font-semibold mb-2">View Emails</h3>
            <p class="text-purple-100 text-sm">Read forwarded emails directly in Telegram</p>
          </div>
          <div class="bg-white bg-opacity-10 rounded-lg p-6">
            <div class="text-white text-3xl mb-3">↩️</div>
            <h3 class="text-white font-semibold mb-2">Reply Anywhere</h3>
            <p class="text-purple-100 text-sm">Reply to emails from Telegram instantly</p>
          </div>
          <div class="bg-white bg-opacity-10 rounded-lg p-6">
            <div class="text-white text-3xl mb-3">⚙️</div>
            <h3 class="text-white font-semibold mb-2">Manage Aliases</h3>
            <p class="text-purple-100 text-sm">Create or delete aliases with simple commands</p>
          </div>
        </div>
        <div class="mt-8">
          <a href="/pricing" class="inline-block px-8 py-3 rounded-lg bg-white text-purple-600 font-semibold hover:bg-gray-100 transition">
            Upgrade to Unlimited
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p>&copy; 2026 Email Me. All rights reserved.</p>
      <div class="flex justify-center space-x-6 mt-4">
        <a href="/terms" class="text-gray-400 hover:text-white">Terms</a>
        <a href="/privacy" class="text-gray-400 hover:text-white">Privacy</a>
        <a href="/contact" class="text-gray-400 hover:text-white">Contact</a>
      </div>
    </div>
  </footer>
</body>
</html>
