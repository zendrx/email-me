<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Aliases - Email Me</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .gradient-bg {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/dashboard" class="text-xl font-bold gradient-bg bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-blue-600">
            Email Me
          </a>
        </div>
        <div class="flex space-x-4">
          <a href="/dashboard" class="text-gray-700 hover:text-gray-900">Dashboard</a>
          <a href="/pricing" class="text-gray-700 hover:text-gray-900">Pricing</a>
          <a href="/logout" class="px-4 py-2 rounded-lg border border-red-600 text-red-600 hover:bg-red-50 transition">
            Logout
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Alias Management Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Email Aliases</h1>
      <p class="text-gray-600">Create and manage email addresses that forward to your inbox.</p>
    </div>

    <!-- Create Alias Form -->
    <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Create New Alias</h2>
      
      <% if error_message %>
        <div class="mb-4 p-3 rounded-lg bg-red-100 border border-red-400 text-red-700">
          <%= error_message %>
        </div>
      <% end %>
      
      <% if success_message %>
        <div class="mb-4 p-3 rounded-lg bg-green-100 border border-green-400 text-green-700">
          <%= success_message %>
        </div>
      <% end %>
      
      <form action="/alias/create" method="POST">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Alias Name</label>
            <div class="flex">
              <input type="text" 
                     name="local_part" 
                     required 
                     pattern="[a-zA-Z0-9._-]+"
                     class="flex-1 rounded-l-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-600"
                     placeholder="yourname">
              <span class="bg-gray-100 border border-l-0 border-gray-300 rounded-r-lg px-3 py-2 text-gray-600">
                @<%= domain %>
              </span>
            </div>
            <p class="text-xs text-gray-500 mt-1">Letters, numbers, dots, underscores, or hyphens only</p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Forward To</label>
            <input type="email" 
                   name="forward_to" 
                   required 
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-600"
                   placeholder="your-real-email@gmail.com">
          </div>
          
          <div class="flex items-end">
            <button type="submit" 
                    class="w-full px-4 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold hover:opacity-90 transition">
              Create Alias
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Aliases List -->
    <div class="bg-white rounded-lg shadow-sm">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Your Aliases</h2>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email Address</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Forwards To</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% if aliases.empty? %>
              <tr>
                <td colspan="4" class="px-6 py-8 text-center text-gray-500">
                  No aliases yet. Create your first alias above.
                </td>
              </tr>
            <% else %>
              <% aliases.each do |alias_item| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">
                      <%= alias_item.full_email %>
                    </div>
                   </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-600">
                      <%= alias_item.forward_to %>
                    </div>
                   </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-500">
                      <%= alias_item.created_at.to_s("%Y-%m-%d") %>
                    </div>
                   </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                    <form action="/alias/delete" method="POST" style="display: inline;" onsubmit="return confirm('Delete <%= alias_item.full_email %>? This cannot be undone.')">
                      <input type="hidden" name="alias_id" value="<%= alias_item.id %>">
                      <button type="submit" class="text-red-600 hover:text-red-800">Delete</button>
                    </form>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Plan Upgrade Prompt for Custom Domains -->
    <% if plan == "Free" && aliases.size >= 1 %>
      <div class="mt-8 gradient-bg rounded-lg p-6">
        <div class="flex justify-between items-center">
          <div>
            <h3 class="text-white font-semibold text-lg mb-1">Need Custom Domains?</h3>
            <p class="text-purple-100 text-sm">Upgrade to Pro or Unlimited to use your own domain names.</p>
          </div>
          <a href="/pricing" class="px-6 py-2 rounded-lg bg-white text-purple-600 font-semibold hover:bg-gray-100 transition">
            View Plans
          </a>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-8 mt-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm">&copy; 2024 Email Me. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
