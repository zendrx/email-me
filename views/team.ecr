<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Team Management - Email Me</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .gradient-bg {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/dashboard" class="text-xl font-bold gradient-bg bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-blue-600">
            Email Me
          </a>
        </div>
        <div class="flex space-x-4">
          <a href="/dashboard" class="text-gray-700 hover:text-gray-900">Dashboard</a>
          <a href="/alias" class="text-gray-700 hover:text-gray-900">Aliases</a>
          <a href="/pricing" class="text-gray-700 hover:text-gray-900">Pricing</a>
          <a href="/logout" class="px-4 py-2 rounded-lg border border-red-600 text-red-600 hover:bg-red-50 transition">
            Logout
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Team Management Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Team Management</h1>
      <p class="text-gray-600">Manage custom domains and team members.</p>
    </div>

    <!-- Messages -->
    <% if success_message %>
      <div class="mb-4 p-3 rounded-lg bg-green-100 border border-green-400 text-green-700">
        <%= success_message %>
      </div>
    <% end %>
    
    <% if error_message %>
      <div class="mb-4 p-3 rounded-lg bg-red-100 border border-red-400 text-red-700">
        <%= error_message %>
      </div>
    <% end %>

    <!-- Add Custom Domain -->
    <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Add Custom Domain</h2>
      <form action="/team/domain/add" method="POST">
        <div class="flex gap-4">
          <input type="text" 
                 name="domain" 
                 required
                 pattern="[a-z0-9.-]+\.[a-z]{2,}"
                 class="flex-1 rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-600"
                 placeholder="yourcompany.com">
          <button type="submit" 
                  class="px-6 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold hover:opacity-90 transition">
            Add Domain
          </button>
        </div>
        <p class="text-xs text-gray-500 mt-2">You'll need to verify domain ownership by adding DNS records.</p>
      </form>
    </div>

    <!-- Domains List -->
    <% if domains.any? %>
      <div class="bg-white rounded-lg shadow-sm mb-8">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">Your Domains</h2>
        </div>
        <div class="divide-y divide-gray-200">
          <% domains.each do |domain| %>
            <div class="p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-md font-semibold text-gray-900"><%= domain.domain %></h3>
                  <div class="flex items-center gap-2 mt-1">
                    <% if domain.verified %>
                      <span class="px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-800">Verified</span>
                    <% else %>
                      <span class="px-2 py-0.5 text-xs rounded-full bg-yellow-100 text-yellow-800">Pending Verification</span>
                    <% end %>
                    <% if domain.is_owner %>
                      <span class="px-2 py-0.5 text-xs rounded-full bg-purple-100 text-purple-800">Owner</span>
                    <% end %>
                  </div>
                </div>
                <% if domain.is_owner && !domain.verified %>
                  <a href="/team/domain/verify?id=<%= domain.id %>" 
                     class="text-sm text-purple-600 hover:text-purple-700">Verify DNS →</a>
                <% end %>
              </div>
              
              <!-- Team Members Section for this Domain -->
              <% if domain.is_owner %>
                <div class="mt-4 pl-4 border-l-2 border-gray-200">
                  <h4 class="text-sm font-semibold text-gray-700 mb-3">Team Members</h4>
                  
                  <!-- Invite Form -->
                  <form action="/team/invite" method="POST" class="flex gap-2 mb-4">
                    <input type="hidden" name="domain_id" value="<%= domain.id %>">
                    <input type="email" 
                           name="invitee_email" 
                           required
                           class="flex-1 rounded-lg border border-gray-300 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-600"
                           placeholder="colleague@example.com">
                    <select name="role" class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm">
                      <option value="member">Member</option>
                      <option value="admin">Admin</option>
                    </select>
                    <button type="submit" 
                            class="px-4 py-1.5 rounded-lg bg-gray-600 text-white text-sm hover:bg-gray-700 transition">
                      Invite
                    </button>
                  </form>
                  
                  <!-- Members List -->
                  <div class="space-y-2">
                    <% team_members[domain.id].each do |member| %>
                      <div class="flex justify-between items-center bg-gray-50 rounded-lg p-3">
                        <div>
                          <div class="text-sm font-medium text-gray-900">
                            <%= member.username %>
                            <% if member.role == "owner" %>
                              <span class="ml-2 text-xs text-purple-600">(Owner)</span>
                            <% elsif member.role == "admin" %>
                              <span class="ml-2 text-xs text-blue-600">(Admin)</span>
                            <% else %>
                              <span class="ml-2 text-xs text-gray-500">(Member)</span>
                            <% end %>
                          </div>
                          <div class="text-xs text-gray-500"><%= member.email %></div>
                        </div>
                        <% if domain.is_owner && member.role != "owner" %>
                          <form action="/team/remove" method="POST" onsubmit="return confirm('Remove <%= member.username %> from team?')">
                            <input type="hidden" name="domain_id" value="<%= domain.id %>">
                            <input type="hidden" name="member_id" value="<%= member.user_id %>">
                            <button type="submit" class="text-red-600 text-sm hover:text-red-800">Remove</button>
                          </form>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="bg-white rounded-lg shadow-sm p-8 text-center">
        <p class="text-gray-500">No custom domains added yet.</p>
        <p class="text-sm text-gray-400 mt-2">Upgrade to Pro or Unlimited to add your own domains.</p>
      </div>
    <% end %>

    <!-- Upgrade Prompt -->
    <% if plan == "Free" %>
      <div class="mt-8 gradient-bg rounded-lg p-6">
        <div class="flex justify-between items-center">
          <div>
            <h3 class="text-white font-semibold text-lg mb-1">Upgrade to Add Custom Domains</h3>
            <p class="text-purple-100 text-sm">Get Pro for $2.99/month or Unlimited for $6.99/month</p>
          </div>
          <a href="/pricing" class="px-6 py-2 rounded-lg bg-white text-purple-600 font-semibold hover:bg-gray-100 transition">
            View Plans
          </a>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-8 mt-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm">&copy; 2024 Email Me. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
